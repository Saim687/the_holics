rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    // Users can only read/write their own data
    match /users/{uid} {
      allow create: if request.auth != null && request.auth.uid == uid;
      allow read, write: if request.auth.uid == uid;
      
      // Subcollections under users
      match /{document=**} {
        allow read, write: if request.auth.uid == uid;
      }
    }
    
    // Public collections (readable by anyone)
    match /skin_services/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /specialists/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /workouts/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /nutrition_plans/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin bank details (read by authenticated users, write by admins only)
    match /admin_settings/bank_details {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Body Holics pricing config (read by authenticated users, write by admins only)
    match /admin_settings/subscription_pricing {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Subscription requests (users create/read their own, admins manage all)
    match /subscription_requests/{uid} {
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.userId == uid
        && request.resource.data.status == 'pending';
      allow read: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null
        && request.auth.uid == uid
        && resource.data.userId == uid
        && resource.data.status != 'active'
        && (request.resource.data.status == resource.data.status
            || request.resource.data.status == 'pending');
      allow delete: if isAdmin();

      // Admins can read/write all subscription requests
      allow read, write: if isAdmin();
    }

    // Appointment slot locks
    match /booked_slots/{slotId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Admin access
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
